{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/_common.schema.json",
  "title": "Common schema definitions",
  "$defs": {
    "type_prefixed_ulid": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_01[0-9A-HJKMNP-TV-Z]{24}$",
      "description": "Lowercase type prefix plus ULID, e.g. req_01HX..."
    },
    "utc_iso8601": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp; use Z suffix for UTC."
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "source_ref": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ]
    }
  }
}
