{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AcceptanceCriteria",
  "type": "object",
  "required": [
    "id",
    "requirement_id",
    "given",
    "when",
    "then",
    "test_id"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^AC-[0-9]{3,}$"
    },
    "requirement_id": {
      "type": "string"
    },
    "given": {
      "type": "string"
    },
    "when": {
      "type": "string"
    },
    "then": {
      "type": "string"
    },
    "test_id": {
      "type": "string"
    }
  }
}