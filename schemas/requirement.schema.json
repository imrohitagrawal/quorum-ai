{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirement",
  "type": "object",
  "required": [
    "id",
    "title",
    "source",
    "owner",
    "priority",
    "acceptance_criteria",
    "tests",
    "jira_status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(FR|NFR|BR)-[0-9]{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "source": {
      "type": "string",
      "minLength": 3
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "priority": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "jira_status": {
      "type": "string"
    }
  }
}