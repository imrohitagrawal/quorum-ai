# Quorum-AI Environment Configuration
# -----------------------------------
# Copy this file to .env and fill in the required values.
# .env is gitignored and should never be committed.
#
# For production on Fly.io: use `fly secrets set KEY=value` instead of
# this file. The Dockerfile does not COPY .env into the image.
# See DEPLOY.md for the full deployment runbook.
#
# Required for live execution:
#   - OPENROUTER_API_KEY: Get from https://openrouter.ai/keys
#   - OPENROUTER_LIVE_EXECUTION_ENABLED: Set to true for live provider calls
#
# Production requirements (when RUNTIME_ENVIRONMENT=production):
#   - SESSION_COOKIE_SECURE must be true
#   - ACCOUNT_LEGACY_HEADER_ENABLED must be false
#   - QUORUM_TOKEN_SECRET must be set to a stable value (multi-instance)

# --- Core Application Settings -----------------------------------------------

# Application name shown in UI and headers
APP_NAME=Quorum-AI

# Runtime environment: local, staging, or production
# Controls security defaults and validation behavior
ENVIRONMENT=local

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- OpenRouter Configuration (REQUIRED FOR LIVE EXECUTION) -----------------

# OpenRouter API key - REQUIRED for live provider calls
# Get your key at: https://openrouter.ai/keys
# Without this, the app runs in local-simulation mode only
OPENROUTER_API_KEY=

# Enable/disable live execution against real providers
# Set to true for live calls, false for simulation mode
OPENROUTER_LIVE_EXECUTION_ENABLED=false

# Base URL for OpenRouter API (rarely needs to change)
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1

# Application URL sent to OpenRouter in requests
# Should be your actual public URL in production (for tracking/support)
OPENROUTER_APP_URL=http://localhost:18084

# Application title sent to OpenRouter
OPENROUTER_APP_TITLE=Quorum AI

# Request timeout in seconds
OPENROUTER_TIMEOUT_SECONDS=8.0

# --- Authentication & Security -----------------------------------------------

# Required in production: set to true when ENVIRONMENT=production
# Ensures session cookies are only sent over HTTPS
SESSION_COOKIE_SECURE=false

# Legacy X-Account-Id header support for testing
# MUST be set to false when ENVIRONMENT=production
ACCOUNT_LEGACY_HEADER_ENABLED=true

# Interactive API docs exposure (/docs, /openapi.json).
# Leave UNSET to derive from ENVIRONMENT: docs are served ONLY in local dev
# and are off-by-default in BOTH staging and production, so an internet-reachable
# box never exposes the unauthenticated schema unless you opt in. Set to true to
# force them on (e.g. a locked-down staging box), or false to force them off.
# /health and /ready are always public and never gated by this flag.
# EXPOSE_API_DOCS=true

# Token secret for confirmation tokens (required for production/multi-instance)
# Generate a strong random value: openssl rand -hex 32
# If not set, a per-process random value is used (tokens break on restart)
# QUORUM_TOKEN_SECRET=

# --- Error Tracking (Optional) -----------------------------------------------

# Sentry DSN for error tracking. Get from:
#   https://sentry.io/settings/[org]/projects/[project]/keys/
# When set, unhandled exceptions and 10% of performance traces
# are reported. When unset, the app runs unaffected.
# SENTRY_DSN=

# --- Pipeline Tuning ---------------------------------------------------------

# Synthetic delay between stages (milliseconds) - for testing visibility
# Production may set this to 0 for maximum performance
STAGE_DELAY_MS=5

# --- Cost Guardrails ---------------------------------------------------------

# Soft threshold in USD - shows warning but allows confirmation
SOFT_THRESHOLD_USD=0.15

# Hard limit in USD - blocks queries exceeding this cost
HARD_LIMIT_USD=0.25

# --- Cost Estimation Multipliers ---------------------------------------------

# Output-to-input token ratio multiplier (industry default: 3.0)
# Higher values = more conservative estimates
COST_OUTPUT_TOKEN_MULTIPLIER=3.0

# Inner call (debate/synthesis) cost multiplier
COST_INNER_CALL_MULTIPLIER=1.5

# Cap per inner call in USD (prevents very long queries from exceeding hard limit)
COST_INNER_CALL_CAP_USD=0.05

# --- Model Selection ---------------------------------------------------------

# Model used for debate rounds (cheap, fast, good at critique)
DEBATE_MODEL_ID=anthropic/claude-haiku-4.5

# Model used for final synthesis (cheap, reliable, structured-output friendly)
SYNTHESIS_MODEL_ID=openai/gpt-4o-mini

# --- Catalog Fetcher ---------------------------------------------------------

# Catalog cache TTL in seconds (6 hours default)
CATALOG_CACHE_TTL_SECONDS=21600.0

# Catalog fetch timeout in seconds
CATALOG_FETCH_TIMEOUT_SECONDS=4.0
