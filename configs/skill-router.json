    {
      "id": "testing-quality",
      "label": "Testing, evaluation, and quality evidence",
      "evidence": [
        "docs/50-test-strategy.md",
        "docs/51-test-data-strategy.md",
        "docs/54-ac-to-test-map.md",
        "docs/55-performance-baseline.md",
        "docs/57-test-evidence.md"
      ],
      "driver": "test-architecture",
      "reviewers": [
        "contract-testing",
        "resilience-testing",
        "test-data-engineering",
        "accessibility-testing",
        "performance-engineering",
        "llm-evaluation",
        "mutation-flaky-test-manager"
      ],
      "blocking_gates": [
        "traceability-graph-gate",
        "enterprise-quality-gatekeeper"
      ],
      "triggers": [
        "AC exists without tests",
        "performance or resilience risk",
        "AI evaluation needed",
        "UI accessibility required"
      ],
      "prompt": "Map every acceptance criterion to tests and evidence. Define unit, integration, contract, E2E, accessibility, performance, security, resilience, and AI eval coverage as applicable."
