{
  "version": "5.2-final",
  "purpose": "Deterministic skill routing for Codex Product Factory. The router recommends exactly one driver skill, reviewer skills, blocking gates, conflict rules, and the next Codex prompt based on product state. V5.1 also routes study artifacts, media, FAQ, technical articles, LinkedIn posts, backend guardrails, and industry/integration practice review. V5.2 adds external-skills-first discovery, future skill onboarding, and session continuity.",
  "selection_order": [
    "safety_security_privacy_compliance_stop_conditions",
    "current_phase",
    "missing_or_placeholder_artifact",
    "artifact_owner_driver_skill",
    "risk_triggers",
    "required_reviewer_skills",
    "blocking_quality_gates",
    "conflict_moderator_if_required"
  ],
  "conflict_precedence": [
    "safety_security_privacy_compliance",
    "explicit_user_approval_within_policy",
    "approved_jira_confluence_source_of_truth",
    "local_factory_policies",
    "adrs_and_architecture_decisions",
    "driver_skill_owned_output",
    "reviewer_skill_findings",
    "external_skill_suggestions"
  ],
  "external_skill_rule": "Search existing skills first. External skills default to reviewer-only until audited, registered, and explicitly promoted. Local policy remains final authority.",
  "orbi_profile_rule": "The ORBI operating model pack is included as an optional profile. It must be activated intentionally; otherwise ORBI-specific Aegis/CiteVyn and Orbisynth rules are not applied to general products.",
  "phases": [
    {
      "id": "idea-intake",
      "label": "Idea intake and clarification",
      "evidence": [
        "PRODUCT_IDEA.md"
      ],
      "driver": "idea-intake-clarifier",
      "reviewers": [
        "next-action-coach",
        "fanatic-critic"
      ],
      "blocking_gates": [
        "no-placeholder-gate"
      ],
      "triggers": [
        "raw idea exists",
        "user provides idea in prompt",
        "PRODUCT_IDEA.md is vague or incomplete"
      ],
      "prompt": "Read PRODUCT_IDEA.md. Ask the smallest useful set of blocking clarifying questions. Do not create requirements, Jira, Confluence, architecture, or code yet."
    },
    {
      "id": "external-skill-governance",
      "label": "External skill discovery and onboarding readiness",
      "evidence": [
        "docs/105-external-skills-first-strategy.md",
        "docs/106-skill-onboarding-runbook.md",
        "docs/107-skills-sh-research-snapshot.md",
        "configs/external-skill-research-index.json",
        "configs/skill-onboarding-policy.json"
      ],
      "driver": "external-skill-discovery-advisor",
      "reviewers": [
        "skill-research-librarian",
        "external-skill-security-auditor",
        "external-skill-onboarding-manager",
        "skill-contract-auditor"
      ],
      "blocking_gates": [
        "skill-onboarding-check",
        "external-skill-security-auditor"
      ],
      "triggers": [
        "new capability needed",
        "user asks for external skills",
        "skills.sh or GitHub skill proposed",
        "avoid reinventing wheel"
      ],
      "prompt": "Before creating a local custom skill, search existing external skills. Recommend reuse, wrap, or build with provenance, security risk, activation mode, and validation plan."
    },
    {
      "id": "session-continuity",
      "label": "Session continuity and handoff",
      "evidence": [
        "docs/108-session-management-with-external-skills.md",
        "docs/session-handoff.md"
      ],
      "driver": "session-continuity-manager",
      "reviewers": [
        "next-action-coach",
        "skill-router-orchestrator",
        "skill-conflict-moderator"
      ],
      "blocking_gates": [
        "make handoff",
        "make skill-route"
      ],
      "triggers": [
        "multiple tabs",
        "multiple terminals",
        "new session",
        "handoff",
        "worktree",
        "context loss"
      ],
      "prompt": "Update session handoff with branch, workstream, driver skill, reviewers, blockers, changed files, validation result, and next prompt. Do not rely on chat history alone."
    },
    {
      "id": "problem-statement",
      "label": "Problem statement",
      "evidence": [
        "docs/04-problem-statement.md"
      ],
      "driver": "problem-statement-builder",
      "reviewers": [
        "product-discovery",
        "fanatic-critic",
        "next-action-coach"
      ],
      "blocking_gates": [
        "requirement-quality-gate"
      ],
      "triggers": [
        "clarifying answers available",
        "problem is not specific",
        "target user or outcome missing"
      ],
      "prompt": "Convert the idea and answers into docs/04-problem-statement.md with user, pain, trigger, current workaround, desired outcome, non-goals, success metrics, assumptions, and open questions."
    },
    {
      "id": "product-discovery",
      "label": "Discovery, opportunity, and roadmap",
      "evidence": [
        "docs/01-product-brief.md",
        "docs/02-stakeholder-map.md",
        "docs/08-prioritization.md",
        "docs/09-roadmap.md"
      ],
      "driver": "product-discovery",
      "reviewers": [
        "mvp-value-outcome-finder",
        "stakeholder-discovery",
        "customer-interview-synthesizer",
        "opportunity-solution-tree-builder",
        "experiment-design",
        "product-prioritization"
      ],
      "blocking_gates": [
        "enterprise-quality-gatekeeper"
      ],
      "triggers": [
        "problem statement approved",
        "roadmap needed",
        "business value unclear",
        "customer evidence missing"
      ],
      "prompt": "Create product brief, stakeholder map, opportunity tree, prioritization, and roadmap. Separate evidence, assumptions, risks, and experiments."
    },
    {
      "id": "requirements",
      "label": "Requirements and acceptance criteria",
      "evidence": [
        "docs/10-functional-requirements.md",
        "docs/11-non-functional-requirements.md",
        "docs/12-acceptance-criteria.md",
        "docs/17-requirement-registry.md"
      ],
      "driver": "requirements-engineering",
      "reviewers": [
        "requirement-quality-gate",
        "acceptance-criteria-quality-gate",
        "nfr-measurability-gate",
        "test-architecture",
        "security-threat-modeling",
        "ai-feature-classifier"
      ],
      "blocking_gates": [
        "requirement-quality-gate",
        "acceptance-criteria-quality-gate",
        "nfr-measurability-gate"
      ],
      "triggers": [
        "approved problem statement",
        "FR/NFR/AC missing",
        "requirements have TBD or vague wording"
      ],
      "prompt": "Create testable FRs, measurable NFRs, Given/When/Then acceptance criteria, requirement registry, and traceability IDs."
    },
    {
      "id": "atlassian-artifacts",
      "label": "Jira and Confluence artifacts",
      "evidence": [
        "docs/34-jira-issue-authoring.md",
        "docs/35-confluence-operational-guide.md",
        "docs/37-jira-confluence-sync-log.md",
        "docs/38-atlassian-integration-roadmap.md"
      ],
      "driver": "jira-confluence-mcp-integration",
      "reviewers": [
        "jira-issue-authoring",
        "confluence-operational-guide-subagent",
        "source-of-truth-reconciler",
        "atlassian-artifact-governance",
        "jira-confluence-change-capture"
      ],
      "blocking_gates": [
        "traceability-graph-gate",
        "source-of-truth-reconciler"
      ],
      "triggers": [
        "Jira issue needed",
        "Confluence guide needed",
        "Atlassian sync requested",
        "docs changed after Jira",
        "Jira changed after docs"
      ],
      "prompt": "Prepare Jira-ready issues and Confluence-ready pages from approved requirements. Do not claim external creation unless an authorized Atlassian tool actually performs it. Record sync status and approval needs."
    },
    {
      "id": "architecture-security-ai",
      "label": "Architecture, UX, security, privacy, and AI safety",
      "evidence": [
        "docs/20-architecture.md",
        "docs/21-domain-model.md",
        "docs/22-api-contract.md",
        "docs/23-data-model.md",
        "docs/30-ux-design.md",
        "docs/40-threat-model.md",
        "docs/42-ai-safety-grounding.md"
      ],
      "driver": "architecture-design",
      "reviewers": [
        "ux-design",
        "security-threat-modeling",
        "privacy-compliance",
        "data-governance",
        "ai-safety-grounding",
        "grounding-contract-builder",
        "prompt-registry-manager",
        "model-risk-register",
        "sre-observability",
        "industry-practices-governor",
        "software-integration-engineering"
