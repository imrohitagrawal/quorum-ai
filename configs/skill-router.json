    {
      "id": "implementation-plan",
      "label": "Implementation planning and vertical slices",
      "evidence": [
        "docs/60-implementation-plan.md",
        "docs/61-vertical-slice-plan.md",
        "docs/62-delivery-decomposition.md",
        "docs/63-technical-debt-register.md",
        "docs/64-feature-flag-plan.md",
        "docs/59-backend-engineering-practices.md"
      ],
      "driver": "implementation-planning",
      "reviewers": [
        "problem-decomposition",
        "vertical-slice-builder",
        "repository-architecture",
        "clean-architecture-enforcer",
        "database-migration",
        "idempotency-concurrency",
        "feature-flag-rollout",
        "technical-debt-manager",
        "python-fastapi-backend-guardrails",
        "software-integration-engineering"
      ],
      "blocking_gates": [
        "enterprise-quality-gatekeeper"
      ],
      "triggers": [
        "approved requirements and architecture",
        "implementation chunking needed",
        "feature flag or migration needed"
      ],
      "prompt": "Break the approved scope into the smallest safe vertical slices with files, tests, risks, rollback, feature flags, and no unapproved scope."
    },
    {
      "id": "build-release-operate",
      "label": "Build, release readiness, and operations",
      "evidence": [
        "docs/70-ci-cd-plan.md",
        "docs/71-release-plan.md",
        "docs/73-release-evidence.md",
        "docs/80-observability.md",
        "docs/83-runbook.md",
        "docs/95-production-readiness-review.md"
