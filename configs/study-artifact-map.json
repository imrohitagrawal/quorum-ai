      "source": "docs/92-visual-asset-plan.md"
    },
    {
      "section": "Operations and Release Evidence",
      "source": "docs/95-production-readiness-review.md"
    }
  ],
  "required_module_blocks": [
    "Problem solved",
    "MVP value outcome",
    "How AI is used",
    "How work becomes easier",
    "Security",
    "Scalability",
    "Enterprise standard",
    "Evidence",
    "Open risks",
    "Next action"
  ],
  "publish_guardrails": [
    "Git-first docs source",
    "Confluence mirrors Git",
    "human confirmation before write",
