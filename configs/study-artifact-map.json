    "security_scale_enterprise": "docs/study/M3-security-scalability-enterprise.md",
    "glossary": "docs/study/glossary.md",
    "faq": "docs/97-faq-wiki-plan.md",
    "technical_article": "docs/98-technical-article-plan.md",
    "linkedin": "docs/99-linkedin-post-plan.md"
  },
  "confluence_page_tree": [
    {
      "section": "Project Overview",
      "source": "docs/study/00-study-index.md"
    },
    {
      "section": "MVP and Problem",
      "source": "docs/study/M1-problem-and-mvp.md"
    },
    {
      "section": "AI Value and Workflow Ease",
      "source": "docs/study/M2-ai-solution-and-work-easing.md"
    },
    {
      "section": "Security, Scalability, Enterprise Readiness",
      "source": "docs/study/M3-security-scalability-enterprise.md"
    },
    {
      "section": "FAQ and Onboarding",
      "source": "docs/97-faq-wiki-plan.md"
    },
    {
